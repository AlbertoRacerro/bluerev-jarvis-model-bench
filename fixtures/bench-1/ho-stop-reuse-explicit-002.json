{
  "schema_version": "bench.case.v1",
  "case_id": "ho-stop-reuse-explicit-002",
  "capability": "HO-STOP",
  "prompt": "A verified result is supplied. Copy inputs.supplied_result into the output field named by inputs.response_contract.output_field. Emit exactly the actions listed in inputs.response_contract.required_actions, in order, and perform no additional work.",
  "inputs": {
    "supplied_result": "stable-result",
    "response_contract": {
      "output_field": "final",
      "required_actions": [
        "return_supplied_result",
        "stop"
      ]
    }
  },
  "expected": {
    "final": "stable-result",
    "actions": [
      "return_supplied_result",
      "stop"
    ]
  },
  "allowed_actions": [
    "return_supplied_result",
    "stop"
  ],
  "forbidden_actions": [
    "call_local_model",
    "call_tool",
    "retry",
    "route_local",
    "delegate_worker",
    "critic_review",
    "propose_improvement",
    "recover",
    "call_external_provider",
    "modify_jarvisos",
    "promote_learning",
    "write_external_state"
  ],
  "success_assertions": [
    "reused_supplied_result",
    "budget_within_limits"
  ],
  "negative_assertions": [
    "no_forbidden_actions",
    "no_external_provider_calls",
    "no_unnecessary_model_calls",
    "no_unnecessary_tool_calls",
    "no_unbounded_retries"
  ],
  "limits": {
    "max_model_calls": 0,
    "max_tool_calls": 0,
    "max_retries": 0
  },
  "required_artifacts": [
    "raw_output",
    "extracted_output",
    "trace",
    "validator_result",
    "environment_fingerprint"
  ]
}
